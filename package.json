{
  "name": "telegram-render-bot",
  "version": "2.0.0",
  "description": "OpenClaw Gateway untuk Telegram di Render",
  "type": "module",
  "scripts": {
    "start": "node scripts/ensure-openclaw-config.mjs && openclaw gateway --bind lan --port $PORT",
    "check": "node --check scripts/ensure-openclaw-config.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "openclaw": "2026.6.11"
  }
}
